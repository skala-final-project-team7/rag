# LINA RAG Pipeline — 환경변수 템플릿
# --------------------------------------------------
# 사용법
#   1. 이 파일을 .env 로 복사:  Copy-Item .env.example .env
#   2. RAG_OPENAI_API_KEY 등 시크릿만 채운다.
#   3. .env 는 .gitignore에 등록돼 있어 커밋되지 않는다 (CLAUDE.md 절대 규칙).
# --------------------------------------------------
# app/config.py 의 Settings 클래스 필드와 1:1 대응. 모든 항목은 기본값이 있어
# 비워두면 기본값이 적용된다. RAG_ 프리픽스 필수.
# --------------------------------------------------

# --- OpenAI (시크릿 — 회사 Mac에서 안전하게 옮길 것) ---
# 빈 문자열이면 LLM 호출 시 401. 본 PoC는 아직 호출 모듈(app/llm/) 미구현이라
# 키 없이도 pytest/demo 동작.
RAG_OPENAI_API_KEY=

# --- 데이터 공급원 (docs/atlassian-api.md) ---
# json_fixture: samples/*.json 기반 (오프라인 동작)
# atlassian:    Confluence REST 직접 호출 (AtlassianSourceAdapter 미구현 — feature 보류)
RAG_SOURCE_TYPE=json_fixture
RAG_SAMPLES_DIR=samples
RAG_ATLASSIAN_API_BASE_URL=https://api.atlassian.com

# --- Qdrant Multi-Pool Vector Store (docs/db-schema.md §1) ---
# docker-compose.yml 사용 시 그대로 동작.
RAG_QDRANT_HOST=localhost
RAG_QDRANT_PORT=6333
RAG_QDRANT_TITLE_POOL=title_pool
RAG_QDRANT_CONTENT_POOL=content_pool
RAG_QDRANT_LABEL_POOL=label_pool

# --- MongoDB (docs/db-schema.md §2 — ingestion_jobs / embedding_cache / rag_mock.*) ---
# docker-compose.yml 사용 시 인증 비활성이므로 그대로 동작.
RAG_MONGO_URI=mongodb://localhost:27017
RAG_MONGO_DB=lina_rag

# --- MySQL (docs/db-schema.md §3 — space_doc_type_cache) ---
# docker-compose.yml 사용 시 user=lina, pw=lina 로 설정됨.
RAG_MYSQL_URI=mysql+pymysql://lina:lina@localhost:3306/lina_rag

# --- LLM 모델 (docs/rag-pipeline-design.md §4) ---
RAG_LLM_ANSWER_MODEL=gpt-4o
RAG_LLM_AUX_MODEL=gpt-4o-mini

# --- 임베딩 / 재순위화 모델 (docs/chunking-strategy.md) ---
RAG_DENSE_EMBEDDING_MODEL=intfloat/multilingual-e5-large
RAG_CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2
RAG_CROSS_ENCODER_TEMPERATURE=4.0
# Cross-Encoder 추론 장치 (feature17c-11). 미설정=자동(보통 CPU). 대형 다국어 reranker
# (예: BAAI/bge-reranker-v2-m3)를 쓸 때 Apple Silicon 은 mps, NVIDIA 는 cuda 로 가속.
# 한국어 변별이 더 필요하고 GPU 가 있으면 모델을 bge 로 교체 검토(CPU 는 지연 KPI 위반).
# RAG_CROSS_ENCODER_DEVICE=mps

# 생성기 환각 보수성 guard (feature17c-14, opt-in). true 면 OpenAI transport 의 system
# 메시지 끝에 보수성 강화 지침(미근거 문장 억제·context 밖 단정 금지)을 덧붙인다
# (vendoring 무수정, 어댑터 경계 주입). 기본 false=기존 동작. A/B: false→true 로 두 번
# 평가해 not_supported_ratio_answerable(feature17c-13) 비교. 과도 시 답변 완성도 하락 가능.
# RAG_GENERATOR_CONSERVATIVE_GUARD=false

# 검증 2단계 전체 top-k grounding (feature17c-19, opt-in). true 면 의심 문장을 인용 청크가
# 아니라 검색된 전체 top-k 근거로 평가 → 환각/차단을 "어느 retrieved 근거로도 미지원"으로만
# 판정(citation 정밀도는 별개). 진단상 잔존 NS 대부분이 오인용 아티팩트라 환각·차단율이 크게
# 내려갈 것으로 예상. 검증·차단(공개) 동작 변경이라 기본 false. A/B + leniency 검증
# (python scripts/run_evaluation.py --debug-leniency "<질의>" --use-real-adapters) 후 채택.
# RAG_VERIFIER_FULL_CONTEXT_GROUNDING=false

# --- 운영 어댑터 토글 (feature16 운영 라이브 smoke) ---
# false (기본): build_poc_deps — :memory: Qdrant + Fake everything + samples 자동 인덱싱.
# true       : build_real_deps — E5 + BM25 + Qdrant.from_settings + CrossEncoderRerankerImpl.
#              모델 다운로드 (~2.4 GB) + Qdrant 서버 + OPENAI_API_KEY 필요.
RAG_USE_REAL_ADAPTERS=false
